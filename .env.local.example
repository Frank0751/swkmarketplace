# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Paystack ────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Cloudinary ──────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Brevo (email) ───────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=info@swkghana.org
BREVO_SENDER_NAME=SWK Marketplace

# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SWK Marketplace

# ─── Commission ──────────────────────────────────────
NEXT_PUBLIC_COMMISSION_RATE=15

# ─── Demo mode ───────────────────────────────────────
# Shows sample vendors/products when the database has none (great for pitching).
# Set to "false" in production once real vendors are live.
NEXT_PUBLIC_DEMO_MODE=true
